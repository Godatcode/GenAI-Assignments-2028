# ──────────────────────────────────────────────────────────────────────────────
# Provider selection
# ──────────────────────────────────────────────────────────────────────────────
# Pick which LLM to use. Optional — if unset, the app auto-detects:
#   GEMINI_API_KEY present  -> uses Gemini
#   OPENAI_API_KEY present  -> uses OpenAI
#   Both present            -> uses Gemini (auto-pref); set LLM_PROVIDER to override
# Allowed values: "gemini" | "openai"
# LLM_PROVIDER=gemini

# ──────────────────────────────────────────────────────────────────────────────
# Google Gemini
# Get a key from https://aistudio.google.com/app/apikey
# ──────────────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
# Optional — defaults to gemini-2.5-flash
GEMINI_MODEL=gemini-2.5-flash

# ──────────────────────────────────────────────────────────────────────────────
# OpenAI
# Get a key from https://platform.openai.com/api-keys
# ──────────────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
# Optional — defaults to gpt-4o-mini
OPENAI_MODEL=gpt-4o-mini
